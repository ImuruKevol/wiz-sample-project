nav(class="sticky top-0 z-20 bg-white shadow dark:bg-zinc-950 dark:border-b dark:border-zinc-800")
    div(class="max-w-4xl px-2 sm:px-4 lg:px-8 py-3 lg:px-6")
        div(class="flex items-center justify-between")
            div(class="flex items-center gap-3")
                button(routerLink="/posts", class="flex items-center justify-center w-8 h-8 rounded-lg hover:bg-gray-100 transition-colors dark:hover:bg-zinc-800")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5 text-gray-500 dark:text-zinc-400")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18")
                h1(class="text-lg font-semibold text-zinc-950 dark:text-zinc-50")
                    span(*ngIf="isNewPost()") {{'post.detail.newPost' | translate}}
                    span(*ngIf="!isNewPost() && data") {{data.title}}
                    span(*ngIf="!isNewPost() && !data") {{'post.detail.loading' | translate}}

    div(class="max-w-4xl px-4 lg:px-8", *ngIf="!isNewPost()")
        div(class="flex gap-0 border-b border-gray-200 dark:border-zinc-800")
            a(*ngFor="let t of tabs",
                routerLink="/posts/{{id}}/{{t.key}}",
                class="px-4 py-2.5 text-[13px] font-medium border-b-2 transition-colors -mb-px cursor-pointer",
                [ngClass]="tab === t.key ? 'border-indigo-600 text-indigo-600 dark:border-indigo-400 dark:text-indigo-300' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-zinc-500 dark:hover:text-zinc-200 dark:hover:border-zinc-700'")
                | {{t.icon}} {{t.labelKey | translate}}

ng-container(*ngIf="data")
    div(class="max-w-4xl pt-6 px-8 pb-8")
        ng-container(*ngIf="tab === 'view'")
            div(class="bg-white rounded-xl border border-gray-200 overflow-hidden dark:bg-zinc-950 dark:border-zinc-800")
                div(class="px-6 py-5 border-b border-gray-100 dark:border-zinc-800")
                    div(class="flex items-center gap-3 mb-3")
                        span(class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800 dark:bg-zinc-800 dark:text-zinc-200", *ngIf="data.category") {{data.category}}
                        span(class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium",
                            [ngClass]="data.status === 'published' ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-yellow-50 text-yellow-700 border border-yellow-200'")
                            | {{data.status}}
                    h2(class="text-xl font-bold text-gray-900 dark:text-zinc-50") {{data.title}}
                    div(class="flex items-center gap-3 mt-3 text-[13px] text-gray-500 dark:text-zinc-400")
                        div(class="flex items-center gap-2")
                            div(class="flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-[10px] font-bold")
                                | {{(data.author || data.author_name)?.charAt(0) || '?'}}
                            span {{data.author || data.author_name}}
                        span · {{data.created}}

                div(class="px-6 py-6")
                    div(class="prose prose-sm max-w-none text-[13px] text-gray-700 leading-relaxed whitespace-pre-wrap dark:text-zinc-300") {{data.content}}

        ng-container(*ngIf="tab === 'edit'")
            div(class="rounded-xl border overflow-hidden bg-white border-gray-200 dark:bg-zinc-950 dark:border-zinc-800")
                div(class="px-6 py-5 border-b border-gray-100 dark:border-zinc-800")
                    h2(class="text-[15px] font-semibold text-gray-900 dark:text-zinc-50")
                        span(*ngIf="isNewPost()") {{'post.detail.newPost' | translate}}
                        span(*ngIf="!isNewPost()") {{'post.detail.editPost' | translate}}
                    p(class="mt-1 text-xs text-gray-500 dark:text-zinc-400") {{'post.detail.editorHelp' | translate}}

                div(class="px-6 py-6 space-y-5")
                    div
                        label(class="block text-[13px] font-medium mb-1 text-gray-700 dark:text-zinc-300") {{'post.detail.titleLabel' | translate}}
                        input(type="text",
                            [(ngModel)]="data.title",
                            [placeholder]="'post.detail.titlePlaceholder' | translate",
                            class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-50 dark:placeholder:text-zinc-500 dark:focus:border-indigo-400 dark:focus:ring-indigo-400")

                    div
                        label(class="block text-[13px] font-medium mb-1 text-gray-700 dark:text-zinc-300") {{'post.detail.categoryLabel' | translate}}
                        select([(ngModel)]="data.category",
                            class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-50 dark:focus:border-indigo-400 dark:focus:ring-indigo-400")
                            option(value="") {{'post.detail.categoryPlaceholder' | translate}}
                            option(*ngFor="let category of categories", [value]="category.value") {{category.labelKey | translate}}

                    div
                        div(class="mb-2 flex items-center justify-between gap-3")
                            label(class="block text-[13px] font-medium text-gray-700 dark:text-zinc-300") {{'post.detail.contentLabel' | translate}}
                            span(class="text-xs text-gray-400 dark:text-zinc-500") Markdown · Monaco Editor
                        div(class="overflow-hidden rounded-lg border border-gray-300 bg-white dark:border-zinc-700 dark:bg-zinc-900")
                            nu-monaco-editor([(ngModel)]="data.content",
                                [options]="editorOptions",
                                height="360px",
                                class="block h-[360px] w-full")

                div(class="px-6 py-4 border-t flex justify-end gap-2 bg-gray-50 border-gray-100 dark:bg-zinc-900 dark:border-zinc-800")
                    button(routerLink="/posts", class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-[13px] font-medium text-gray-700 shadow-sm hover:bg-gray-50 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-200 dark:hover:bg-zinc-800") {{'post.detail.cancel' | translate}}
                    button((click)="save()",
                        [disabled]="saving",
                        class="inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-indigo-500 disabled:opacity-50")
                        svg(class="animate-spin size-4 mr-2", viewBox="0 0 24 24", *ngIf="saving")
                            circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4")
                            path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                        | {{'post.detail.save' | translate}}

        ng-container(*ngIf="tab === 'settings'")
            div(class="bg-white rounded-xl border border-gray-200 overflow-hidden dark:bg-zinc-950 dark:border-zinc-800")
                div(class="px-6 py-5 border-b border-gray-100 dark:border-zinc-800")
                    h2(class="text-[15px] font-semibold text-gray-900 dark:text-zinc-50") {{'post.detail.settingsTitle' | translate}}

                div(class="px-6 py-6 space-y-5")
                    div
                        label(class="block text-[13px] font-medium text-gray-700 mb-1 dark:text-zinc-300") {{'post.detail.statusLabel' | translate}}
                        select([(ngModel)]="data.status",
                            class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-50 dark:focus:border-indigo-400 dark:focus:ring-indigo-400")
                            option(*ngFor="let status of statuses", [value]="status.value") {{status.labelKey | translate}}

                    div(class="border-t border-gray-200 pt-5 dark:border-zinc-800")
                        h3(class="text-[13px] font-semibold text-gray-900 mb-3 dark:text-zinc-50") {{'post.detail.metaInfo' | translate}}
                        div(class="space-y-3")
                            div(class="flex items-center justify-between text-[13px]")
                                span(class="text-gray-500 dark:text-zinc-400") {{'post.detail.postId' | translate}}
                                span(class="font-mono text-gray-900 dark:text-zinc-100") {{data.id}}
                            div(class="flex items-center justify-between text-[13px]")
                                span(class="text-gray-500 dark:text-zinc-400") {{'post.detail.author' | translate}}
                                span(class="text-gray-900 dark:text-zinc-100") {{data.author || data.author_name || '-'}}
                            div(class="flex items-center justify-between text-[13px]")
                                span(class="text-gray-500 dark:text-zinc-400") {{'post.detail.created' | translate}}
                                span(class="text-gray-900 dark:text-zinc-100") {{data.created}}
                            div(class="flex items-center justify-between text-[13px]")
                                span(class="text-gray-500 dark:text-zinc-400") {{'post.detail.updated' | translate}}
                                span(class="text-gray-900 dark:text-zinc-100") {{data.updated || '-'}}

                div(class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex items-center justify-between dark:bg-zinc-900 dark:border-zinc-800")
                    button((click)="remove()",
                        class="inline-flex items-center rounded-lg border border-red-300 bg-white px-4 py-2 text-[13px] font-medium text-red-600 shadow-sm hover:bg-red-50")
                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4 mr-1")
                            path(stroke-linecap="round", stroke-linejoin="round", d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0")
                        | {{'post.detail.deleteAction' | translate}}
                    button((click)="save()",
                        [disabled]="saving",
                        class="inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-indigo-500 disabled:opacity-50")
                        | {{'post.detail.saveSettings' | translate}}

ng-container(*ngIf="!data && !isNewPost()")
    div(class="max-w-4xl pt-6 px-8 pb-8")
        div(class="flex justify-center py-12")
            p(class="text-[13px] text-gray-400") {{'post.detail.loading' | translate}}
